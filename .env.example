# ============================================================
# Keystatic Environment Variables
# ============================================================
# Copy this file to .env and fill in the values
# Only needed for production (GitHub OAuth mode)
# In development, Keystatic uses local storage mode

# --- Keystatic GitHub OAuth ---
# Create OAuth App: https://github.com/settings/developers
# Homepage URL: https://snhgn.me
# Authorization callback URL: https://snhgn.me/api/keystatic/oauth/callback
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=

# Keystatic Secret (random string for session encryption)
# Generate with: openssl rand -hex 32
KEYSTATIC_SECRET=

# GitHub repo (for Keystatic GitHub storage)
GITHUB_REPO_OWNER=snhgn
GITHUB_REPO_NAME=snhgn.me

# --- Webhook (for auto-rebuild) ---
# Secret used to verify GitHub webhook signatures
# Must match the secret configured in GitHub Webhook settings
WEBHOOK_SECRET=

# Path to build script on the server
BUILD_SCRIPT=/home/a/build.sh
